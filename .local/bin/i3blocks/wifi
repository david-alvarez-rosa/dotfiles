#!/usr/bin/env sh

INTERFACE="${BLOCK_INSTANCE:-wlan0}"

printf "<span font_family='FontAwesome'></span> "

if [ ! -d "/sys/class/net/$INTERFACE/wireless" ] ||
   [ "$(cat "/sys/class/net/$INTERFACE/operstate")" = down ]; then
    echo "Off"
    exit
fi

awk -v i="$INTERFACE" '$0 ~ i { print int($3 * 100 / 70) "%" }' /proc/net/wireless
