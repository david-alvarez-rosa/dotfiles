#!/bin/bash

bat=/sys/class/power_supply/BAT0
percentage=$(< "$bat/capacity")
state=$(< "$bat/status")

function notifyBatteryInfo() {
    info=$(upower --battery)
    time=$(echo "$info" | awk '/time to/ {print $4, $5}')
    rate=$(echo "$info" | awk '/energy-rate:/ {print $2, $3}')
    capacity=$(echo "$info" | awk '/energy-full:/ {print $2, $3}')
    design=$(echo "$info" | awk '/energy-full-design:/ {print $2, $3}')
    health=$(echo "$info" | awk '/capacity:/ {sub(/%/, "", $2); printf "%.1f%%", $2}')
    profile=$(tlp-stat -s 2>/dev/null | awk -F'= ' '/TLP profile/ {print $2}')

    case $state in
        Discharging) eta="Time to empty: ${time:-calculating…}" ;;
        Charging)    eta="Time to full: ${time:-calculating…}" ;;
    esac

    body="Status: $percentage% ($state)
${eta:+$eta
}Energy rate: $rate
Capacity: $capacity / $design ($health)
TLP profile: ${profile:-unknown}"

    notify-send "Battery information" "$body"
}

case $BLOCK_BUTTON in
    1|2|3) notifyBatteryInfo ;;
esac

if [ "$state" = "Discharging" ]; then
    if   [ "$percentage" -lt 20 ]; then icon=''
    elif [ "$percentage" -lt 40 ]; then icon=''
    elif [ "$percentage" -lt 60 ]; then icon=''
    elif [ "$percentage" -lt 85 ]; then icon=''
    else                                icon=''
    fi
else
    icon=''
fi

printf "<span font_family='FontAwesome'>$icon</span> %s%%\n" "$percentage"
