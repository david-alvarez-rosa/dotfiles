#!/bin/sh

case $BLOCK_BUTTON in
  1) notify-send "Available updates" "$(checkupdates --nocolor 2>/dev/null | awk '{print $1}')" ;;
esac

number=$(checkupdates --nocolor 2>/dev/null | wc -l)

printf "<span font_family='monospace'>\357\214\203</span>  "
printf "<span color='white'>"
if [ "$number" -eq 0 ]; then
  printf "up to date"
elif [ "$number" -eq 1 ]; then
  printf "%s update" "$number"
else
  printf "%s updates" "$number"
fi
printf "</span>\n"
