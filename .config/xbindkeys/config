"wpctl set-volume @DEFAULT_AUDIO_SINK@ 10%+"
  XF86AudioRaiseVolume
"wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
  Shift + XF86AudioRaiseVolume
"wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+"
  Control + XF86AudioRaiseVolume

"wpctl set-volume @DEFAULT_AUDIO_SINK@ 10%-"
  XF86AudioLowerVolume
"wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  Shift + XF86AudioLowerVolume
"wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-"
  Control + XF86AudioLowerVolume

"wpctl set-volume @DEFAULT_AUDIO_SINK@ 0; wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  XF86AudioMute

"wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"
  XF86AudioMicMute

"xbacklight -inc 10"
  XF86MonBrightnessUp
"xbacklight -inc 20"
  Shift + XF86MonBrightnessUp
"xbacklight -inc 5"
  Control + XF86MonBrightnessUp

"xbacklight -dec 10"
  XF86MonBrightnessDown
"xbacklight -dec 20"
  Shift + XF86MonBrightnessDown
"xbacklight -dec 5"
  Control + XF86MonBrightnessDown

"id=$(xinput list | grep -i touchpad | grep -o 'id=[0-9]*' | head -1 | cut -d= -f2); xinput list-props $id | grep -q 'Device Enabled.*1$' && xinput disable $id || xinput enable $id"
  XF86Display

"if [ -e /tmp/.zoom ]; then xrandr --output eDP-1 --auto; rm /tmp/.zoom; else xrandr --output eDP-1 --mode 1280x800; touch /tmp/.zoom; fi"
  XF86Favorites

"mpc toggle"
  XF86AudioPlay
"mpc prev"
  XF86AudioPrev
"mpc next"
  XF86AudioNext

"i3lock -i ~/media/wallpaper.png -u"
  Mod4 + l

"maim -u | tee ~/tmp/$(date +'%Y%m%d-%H:%M:%S').png | xclip -selection clipboard -t image/png"
  Print
"maim -u --window $(xdotool getactivewindow) | tee ~/tmp/$(date +'%Y%m%d-%H:%M:%S').png | xclip -selection clipboard -t image/png"
  Shift + Print
"maim -u --select | tee ~/tmp/$(date +'%Y%m%d-%H:%M:%S').png | xclip -selection clipboard -t image/png"
  Control + Print

"dmenu_run -fn 'monospace:size=11'"
  Mod4 + d
