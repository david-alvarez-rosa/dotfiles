xremap ~/.config/xremap/config.yml & sleep 2 && xset r rate 275 60 && setxkbmap -layout us,es -option grp:win_space_toggle,compose:ralt &
xmodmap -e "keycode 248 = Tab" -e "keycode 23 = Super_L" && xcape -e "Super_L=Tab"
xbindkeys -f ~/.config/xbindkeys/config
unclutter --timeout 2 --ignore-scrolling &
xrdb -merge ~/.config/X11/Xresources
keepassxc &
dunst &
systemctl --user import-environment DISPLAY XAUTHORITY
exec i3
