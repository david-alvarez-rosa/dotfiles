);

CREATE TABLE tags (
    entry TEXT NOT NULL,
    feed TEXT NOT NULL,
    tag TEXT NOT NULL,
    FOREIGN KEY (entry, feed) REFERENCES entries (id, feed)
);

(fn FEEDS-FILE ENTRIES-FILE TAGS-FILE &key HEADERS-P)")
