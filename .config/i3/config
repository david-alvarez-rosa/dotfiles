font pango:monospace 11

gaps inner 4
gaps outer 2
default_border pixel 1

#                       border  backgr. text    indicator child
client.focused          #555555 #555555 #ffffff #555555   #555555
client.focused_inactive #222222 #222222 #888888 #222222   #222222
client.unfocused        #222222 #222222 #888888 #222222   #222222
client.urgent           #900000 #900000 #ffffff #900000   #900000

set $mod Mod4

focus_wrapping no

set $ws1 "1. Emacs"
set $ws2 "2. Browser"
set $ws3 "3. Terminal"
set $ws4 "4. Executing"
set $ws5 "5. Extra"
set $ws6 "6. Extra"
set $ws7 "7. Emacs"
set $ws8 "8. Browser"
set $ws9 "9. Terminal"
set $ws10 "10. Executing"

exec --no-startup-id env XDG_CURRENT_DESKTOP=i3 /usr/lib/xdg-desktop-portal-gtk
exec --no-startup-id env XDG_CURRENT_DESKTOP=i3 /usr/lib/xdg-desktop-portal -r

exec --no-startup-id i3-msg "exec emacs"
exec --no-startup-id i3-msg "exec firefox"
exec --no-startup-id "sh -c 'until i3-msg [class=firefox] move container to workspace 2. Browser; do sleep 0.5; done'"

exec --no-startup-id sh -c 'until ssh-add -l >/dev/null 2>&1; do sleep 0.5; done; nextcloud --background'

exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -i ~/media/wallpaper.png -u

exec_always --no-startup-id feh --no-fehbg --bg-fill ~/media/wallpaper.png

bindsym $mod+Return exec emacsclient -c
bindsym $mod+Shift+Return exec emacsclient -c -e "(vterm t)"
bindsym $mod+r exec --no-startup-id rofi -show drun
bindsym $mod+l exec --no-startup-id i3lock -i ~/media/wallpaper.png -u
bindsym $mod+d exec --no-startup-id dark-mode-toggle
bindsym $mod+space exec --no-startup-id "setxkbmap -query | grep -qE 'layout:[[:space:]]*es' && setxkbmap -layout us,es -option '' -option compose:ralt || setxkbmap -layout es,us -option '' -option compose:ralt; pkill -RTMIN+2 i3blocks"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

bindsym $mod+Tab workspace back_and_forth

for_window [class="mpv"] floating enable; exec --no-startup-id ~/.local/bin/bottomright
for_window [class="mpv"] sticky enable

for_window [class="KeePassXC"] floating enable

bindsym $mod+q kill

bindsym $mod+b exec emacs-i3-integration focus left
bindsym $mod+n exec emacs-i3-integration focus down
bindsym $mod+p exec emacs-i3-integration focus up
bindsym $mod+f exec emacs-i3-integration focus right

bindsym $mod+t focus mode_toggle

bindsym $mod+Shift+b exec emacs-i3-integration move left 20px
bindsym $mod+Shift+n exec emacs-i3-integration move down 20px
bindsym $mod+Shift+p exec emacs-i3-integration move up 20px
bindsym $mod+Shift+f exec emacs-i3-integration move right 20px

floating_modifier $mod

bindsym $mod+Control+f exec --no-startup-id "~/.local/bin/i3resize right"
bindsym $mod+Control+p exec --no-startup-id "~/.local/bin/i3resize up"
bindsym $mod+Control+n exec --no-startup-id "~/.local/bin/i3resize down"
bindsym $mod+Control+b exec --no-startup-id "~/.local/bin/i3resize left"

bindsym $mod+v split vertical
bindsym $mod+h split horizontal

bindsym $mod+s layout toggle tabbed split

bindsym $mod+Shift+t floating toggle
bindsym $mod+Shift+s sticky toggle

bindsym $mod+o fullscreen toggle

bindsym $mod+Shift+v floating toggle; exec --no-startup-id ~/.local/bin/bottomright; sticky enable

bar {
    font pango:DejaVu Sans Mono 9
    status_command i3blocks
    height 31
    position top
    mode dock
    tray_output none
}
